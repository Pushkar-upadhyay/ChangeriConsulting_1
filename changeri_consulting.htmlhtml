    <button class="harr" onclick="pSlide()"><i class="fa-solid fa-chevron-left"></i></button>
    <button class="harr" onclick="nSlide()"><i class="fa-solid fa-chevron-right"></i></button>
  </div>
</section>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-track">
    <span>Tax Consulting</span><i class="fa-solid fa-diamond"></i>
