<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Changeri Consulting – Enterprise IT Solutions</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=IBM+Plex+Serif:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  /* IBM / Enterprise IT color palette */
  --bg:       #f4f7fb;
  --bg2:      #eef2f8;
  --bg3:      #e4eaf4;
  --navy:     #001141;
  --navy2:    #002263;
  --blue:     #0353a4;
  --blue-lt:  #0066cc;
  --sky:      #198ec8;
  --teal:     #009c8f;
  --slate:    #3a4f6b;
  --white:    #ffffff;
  --off:      #f9fbff;
  --muted:    #64748b;
  --muted2:   #94a3b8;
  --border:   #d0dce8;
  --border2:  #b8cce0;
  --text:     #0f1c35;
  --card:     #ffffff;
  --success:  #12836e;
  --grad1: linear-gradient(135deg,#0353a4 0%,#009c8f 100%);
  --grad2: linear-gradient(135deg,#001141 0%,#0353a4 100%);
  --grad3: linear-gradient(90deg,#0353a4,#198ec8,#009c8f);
}
html{scroll-behavior:smooth}
body{font-family:'IBM Plex Sans',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;line-height:1.6}

/* ─── NAVBAR ─── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:2000;
  background:var(--navy);
  border-bottom:1px solid rgba(255,255,255,0.08);
  transition:box-shadow 0.3s;
}
nav.scrolled{box-shadow:0 4px 30px rgba(0,17,65,0.35)}
.nav-top{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 2.5rem;height:64px;
}
.nav-brand{
  font-family:'IBM Plex Serif',serif;font-size:1.15rem;font-weight:600;
  text-decoration:none;color:#fff;letter-spacing:0.01em;
  display:flex;align-items:center;gap:0.6rem;flex-shrink:0;
}
.brand-icon{
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.nav-right{display:flex;align-items:center;gap:0.5rem}
.nav-links{display:flex;align-items:stretch;list-style:none;height:64px}
.nav-item{position:static;display:flex;align-items:stretch}
.nav-btn{
  background:none;border:none;cursor:pointer;
  padding:0 1.1rem;color:rgba(255,255,255,0.78);
  font-size:0.8rem;font-family:'IBM Plex Sans',sans-serif;
  font-weight:400;letter-spacing:0.03em;
  display:flex;align-items:center;gap:0.4rem;
  border-bottom:2px solid transparent;
  transition:color 0.2s,border-color 0.2s;
  white-space:nowrap;
}
.nav-btn i{font-size:0.6rem;transition:transform 0.25s}
.nav-btn:hover,.nav-item.open .nav-btn{color:#fff;border-bottom-color:#198ec8}
.nav-item.open .nav-btn i{transform:rotate(180deg)}
.nav-link-plain{
  padding:0 1rem;color:rgba(255,255,255,0.78);text-decoration:none;
  font-size:0.8rem;font-weight:400;letter-spacing:0.03em;
  display:flex;align-items:center;border-bottom:2px solid transparent;
  transition:color 0.2s,border-color 0.2s;white-space:nowrap;
}
.nav-link-plain:hover{color:#fff;border-bottom-color:#198ec8}
.nav-search-wrap{display:flex;align-items:center;border-left:1px solid rgba(255,255,255,0.12);padding-left:1rem;margin-left:0.5rem}
.nav-search{
  background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.18);
  padding:0.42rem 0.9rem 0.42rem 2.2rem;color:#fff;
  font-family:'IBM Plex Sans',sans-serif;font-size:0.78rem;outline:none;
  border-radius:4px;width:160px;transition:all 0.3s;
}
.nav-search::placeholder{color:rgba(255,255,255,0.45)}
.nav-search:focus{border-color:var(--sky);width:200px;background:rgba(255,255,255,0.12)}
.search-icon{position:relative;display:flex;align-items:center}
.search-icon i{position:absolute;left:0.65rem;font-size:0.75rem;color:rgba(255,255,255,0.45);pointer-events:none}
.btn-cta{
  padding:0.48rem 1.3rem;border-radius:4px;
  background:var(--grad1);color:#fff;border:none;
  font-family:'IBM Plex Sans',sans-serif;font-size:0.78rem;font-weight:600;
  letter-spacing:0.04em;cursor:pointer;text-decoration:none;display:inline-flex;
  align-items:center;gap:0.4rem;transition:opacity 0.2s,transform 0.2s;white-space:nowrap;
}
.btn-cta:hover{opacity:0.9;transform:translateY(-1px)}
.btn-signin{
  padding:0.42rem 1.1rem;border-radius:4px;
  background:transparent;border:1px solid rgba(255,255,255,0.35);
  color:rgba(255,255,255,0.85);font-family:'IBM Plex Sans',sans-serif;
  font-size:0.78rem;cursor:pointer;text-decoration:none;
  display:inline-flex;align-items:center;gap:0.35rem;
  transition:all 0.2s;white-space:nowrap;
}
.btn-signin:hover{background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.6)}

/* ─── MEGA DROPDOWN ─── */
.mega-panel{
  display:none;position:fixed;
  top:64px;left:0;right:0;z-index:1999;
  background:var(--white);
  border-top:3px solid var(--blue);
  box-shadow:0 12px 48px rgba(0,17,65,0.18);
  padding:0;
  animation:slideDown 0.22s ease forwards;
}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.nav-item.open .mega-panel{display:block}
.mega-inner{
  max-width:1200px;margin:0 auto;padding:2.5rem;
  display:grid;gap:2.5rem;
}
.mega-inner.cols-3{grid-template-columns:repeat(3,1fr)}
.mega-inner.cols-4{grid-template-columns:repeat(4,1fr)}
.mega-col-title{
  font-size:0.62rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--blue);margin-bottom:1rem;padding-bottom:0.6rem;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:0.5rem;
}
.mega-col-title i{font-size:0.75rem}
.mega-item{
  display:flex;align-items:flex-start;gap:0.85rem;
  padding:0.7rem 0.75rem;border-radius:6px;text-decoration:none;
  transition:background 0.18s;cursor:pointer;
}
.mega-item:hover{background:var(--bg2)}
.mega-item-icon{
  width:36px;height:36px;border-radius:8px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:0.85rem;
}
.ic-blue{background:#e8f0fb;color:var(--blue)}
.ic-teal{background:#e6f5f4;color:var(--teal)}
.ic-navy{background:#e8eaf0;color:var(--navy2)}
.ic-sky{background:#e5f4fb;color:var(--sky)}
.ic-orange{background:#fff3e8;color:#c55a11}
.mega-item-text h4{font-size:0.82rem;font-weight:600;color:var(--text);line-height:1.3;margin-bottom:0.15rem}
.mega-item-text p{font-size:0.72rem;color:var(--muted);line-height:1.4}
.mega-footer{
  background:var(--bg2);border-top:1px solid var(--border);
  padding:1rem 2.5rem;
  display:flex;align-items:center;justify-content:space-between;
}
.mega-footer-link{
  display:flex;align-items:center;gap:0.45rem;
  font-size:0.78rem;font-weight:600;color:var(--blue);text-decoration:none;
  transition:gap 0.2s;
}
.mega-footer-link:hover{gap:0.7rem}
.mega-overlay{
  display:none;position:fixed;inset:0;top:64px;
  background:rgba(0,17,65,0.25);z-index:1998;
}
.mega-overlay.show{display:block}

/* ─── HERO ─── */
.hero{position:relative;height:100vh;min-height:640px;overflow:hidden;padding-top:64px}
.slide{position:absolute;inset:0;padding-top:64px;display:flex;align-items:center;opacity:0;transition:opacity 0.9s ease}
.slide.active{opacity:1}
.slide-bg{position:absolute;inset:0;background-size:cover;background-position:center;transform:scale(1.04);transition:transform 7s ease}
.slide.active .slide-bg{transform:scale(1)}
.slide-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(105deg,rgba(0,17,65,0.92) 40%,rgba(0,34,99,0.55) 100%)}
.slide-content{position:relative;z-index:2;padding:0 6rem;max-width:860px}
.slide-eyebrow{
  display:inline-flex;align-items:center;gap:0.6rem;
  padding:0.38rem 1rem;margin-bottom:1.5rem;
  background:rgba(25,142,200,0.2);border:1px solid rgba(25,142,200,0.4);
  border-radius:20px;font-size:0.65rem;font-weight:600;
  letter-spacing:0.15em;text-transform:uppercase;color:#5fcfff;
  opacity:0;transform:translateY(16px);transition:all 0.55s 0.2s;
}
.slide.active .slide-eyebrow{opacity:1;transform:translateY(0)}
.slide-eyebrow i{font-size:0.6rem}
.slide-h1{
  font-family:'IBM Plex Serif',serif;font-size:clamp(2.8rem,6vw,5.2rem);
  font-weight:300;line-height:1.05;color:#fff;margin-bottom:1.2rem;
  opacity:0;transform:translateY(24px);transition:all 0.65s 0.35s;
}
.slide.active .slide-h1{opacity:1;transform:translateY(0)}
.slide-h1 strong{font-weight:600;color:#5fcfff}
.slide-p{
  font-size:1rem;font-weight:300;color:rgba(255,255,255,0.78);
  line-height:1.75;margin-bottom:2.5rem;max-width:560px;
  opacity:0;transform:translateY(16px);transition:all 0.6s 0.5s;
}
.slide.active .slide-p{opacity:1;transform:translateY(0)}
.slide-btns{
  display:flex;gap:1rem;flex-wrap:wrap;
  opacity:0;transform:translateY(16px);transition:all 0.6s 0.65s;
}
.slide.active .slide-btns{opacity:1;transform:translateY(0)}
.btn-primary-hero{
  padding:0.85rem 2.2rem;border-radius:4px;
  background:var(--blue-lt);color:#fff;border:2px solid var(--blue-lt);
  font-family:'IBM Plex Sans',sans-serif;font-size:0.82rem;
  font-weight:600;letter-spacing:0.06em;cursor:pointer;
  text-decoration:none;display:inline-flex;align-items:center;gap:0.5rem;
  transition:background 0.22s,transform 0.2s;
}
.btn-primary-hero:hover{background:#0052a3;border-color:#0052a3;transform:translateY(-2px)}
.btn-ghost-hero{
  padding:0.85rem 2.2rem;border-radius:4px;
  background:transparent;border:2px solid rgba(255,255,255,0.55);
  color:#fff;font-family:'IBM Plex Sans',sans-serif;
  font-size:0.82rem;font-weight:500;letter-spacing:0.06em;
  cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:0.5rem;
  transition:all 0.22s;
}
.btn-ghost-hero:hover{background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.85)}
.hero-nav{position:absolute;bottom:2.5rem;left:6rem;z-index:10;display:flex;align-items:center;gap:1rem}
.hdot{
  width:28px;height:3px;background:rgba(255,255,255,0.3);cursor:pointer;
  border-radius:2px;transition:all 0.3s;
}
.hdot.active{width:52px;background:var(--sky)}
.hero-arrows{position:absolute;bottom:2rem;right:4rem;z-index:10;display:flex;gap:0.6rem}
.harr{
  width:44px;height:44px;display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.25);
  color:#fff;font-size:0.9rem;cursor:pointer;border-radius:4px;transition:all 0.22s;
}
.harr:hover{background:rgba(255,255,255,0.2);border-color:rgba(255,255,255,0.6)}

/* ─── TICKER ─── */
.ticker{
  background:var(--navy2);border-bottom:3px solid var(--blue);
  padding:0.65rem 0;overflow:hidden;
}
.ticker-track{display:flex;animation:tickRun 30s linear infinite;white-space:nowrap}
.ticker-track span{padding:0 2.5rem;font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.7);font-weight:400}
.ticker-track i{color:var(--sky);font-size:0.5rem;padding:0 0.5rem;vertical-align:middle}
@keyframes tickRun{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ─── SECTION LAYOUT ─── */
.section-wrap{padding:6rem 6rem}
.section-wrap.alt{background:var(--bg2)}
.section-wrap.dark{background:var(--navy);color:#fff}
.section-label{
  display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;
  font-size:0.65rem;letter-spacing:0.25em;text-transform:uppercase;font-weight:600;
  color:var(--blue);
}
.section-label::before{content:'';width:28px;height:2px;background:var(--blue);border-radius:1px}
.section-title{
  font-family:'IBM Plex Serif',serif;
  font-size:clamp(1.9rem,3.5vw,2.8rem);font-weight:400;
  line-height:1.2;margin-bottom:1.5rem;color:var(--navy);
}
.section-title .hl{color:var(--blue);font-weight:600}
.section-title.light{color:#fff}
.section-title.light .hl{color:#5fcfff}

/* ─── ABOUT ─── */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.about-desc{font-size:0.92rem;color:var(--muted);line-height:1.85;margin-bottom:1.2rem;font-weight:300}
.feat-list{list-style:none;display:flex;flex-direction:column;gap:0.6rem;margin-bottom:2rem}
.feat-list li{
  display:flex;align-items:center;gap:0.75rem;
  font-size:0.82rem;color:var(--text);font-weight:400;
}
.feat-list li i{color:var(--teal);font-size:0.8rem;width:16px;flex-shrink:0}
.about-img-wrap{position:relative}
.about-img{width:100%;border-radius:8px;display:block;box-shadow:0 20px 60px rgba(0,17,65,0.15)}
.about-badge{
  position:absolute;bottom:-1.5rem;left:-1.5rem;
  background:var(--navy);color:#fff;
  padding:1.4rem 2rem;border-radius:8px;
  box-shadow:0 8px 32px rgba(0,17,65,0.3);
  display:flex;flex-direction:column;align-items:center;
  border-left:4px solid var(--sky);
}
.badge-num{font-family:'IBM Plex Serif',serif;font-size:2.2rem;font-weight:600;color:#5fcfff;line-height:1}
.badge-lbl{font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.65);margin-top:0.2rem}

/* ─── STATS ─── */
.stats-band{
  background:var(--navy2);display:grid;grid-template-columns:repeat(3,1fr);
}
.stat{
  padding:3rem 2.5rem;border-right:1px solid rgba(255,255,255,0.1);
  text-align:center;position:relative;overflow:hidden;
  transition:background 0.3s;
}
.stat:last-child{border-right:none}
.stat:hover{background:rgba(255,255,255,0.04)}
.stat::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:3px;
  background:var(--grad3);transform:scaleX(0);transform-origin:left;
  transition:transform 0.5s;
}
.stat:hover::after{transform:scaleX(1)}
.stat-num{
  font-family:'IBM Plex Serif',serif;font-size:3rem;font-weight:400;
  color:#fff;line-height:1;margin-bottom:0.4rem;
}
.stat-num span{color:var(--sky);font-weight:600}
.stat-lbl{font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.55);font-weight:400}

/* ─── TRUSTED ─── */
.trusted-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.trusted-img-wrap{position:relative;order:-1}
.trusted-img{width:100%;border-radius:8px;display:block;box-shadow:0 20px 60px rgba(0,17,65,0.15)}
.overlay-badge{
  position:absolute;top:2rem;right:-1.5rem;
  background:#fff;padding:1.2rem 1.5rem;border-radius:8px;
  box-shadow:0 8px 32px rgba(0,17,65,0.2);
  text-align:center;border-top:4px solid var(--teal);
}
.overlay-badge .num{font-family:'IBM Plex Serif',serif;font-size:1.8rem;font-weight:600;color:var(--teal);line-height:1}
.overlay-badge .lbl{font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-top:0.15rem}
.trusted-sub{
  font-family:'IBM Plex Serif',serif;font-size:1.05rem;font-weight:400;
  font-style:italic;color:var(--muted);margin-bottom:1.75rem;
}

/* ─── SERVICES ─── */
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.svc-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:8px;overflow:hidden;
  transition:transform 0.3s,box-shadow 0.3s,border-color 0.3s;
  cursor:default;
}
.svc-card:hover{
  transform:translateY(-5px);
  border-color:var(--blue);
  box-shadow:0 16px 48px rgba(3,83,164,0.14);
}
.svc-img{width:100%;aspect-ratio:16/9;object-fit:cover;display:block}
.svc-body{padding:1.75rem}
.svc-icon-wrap{
  width:44px;height:44px;border-radius:10px;margin-bottom:1rem;
  display:flex;align-items:center;justify-content:center;font-size:1rem;
}
.ic1{background:#e8f0fb;color:var(--blue)}
.ic2{background:#e6f5f4;color:var(--teal)}
.ic3{background:#e5f0f7;color:var(--sky)}
.svc-title{
  font-family:'IBM Plex Serif',serif;font-size:1.1rem;font-weight:400;
  color:var(--navy);margin-bottom:0.6rem;
}
.svc-desc{font-size:0.82rem;color:var(--muted);line-height:1.7;margin-bottom:1rem;font-weight:300}
.svc-link{
  display:inline-flex;align-items:center;gap:0.4rem;
  font-size:0.75rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;
  color:var(--blue);text-decoration:none;transition:gap 0.2s;
}
.svc-link:hover{gap:0.65rem}

/* ─── CONTACT INFO CARDS ─── */
.contact-cards{
  background:var(--navy);padding:4rem 6rem;
  display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;
}
.ci-card{
  background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
  border-radius:8px;padding:1.75rem;
  transition:background 0.25s,border-color 0.25s;
}
.ci-card:hover{background:rgba(255,255,255,0.09);border-color:rgba(25,142,200,0.5)}
.ci-icon{
  width:44px;height:44px;border-radius:10px;margin-bottom:1rem;
  display:flex;align-items:center;justify-content:center;font-size:1rem;
}
.ci1{background:rgba(3,83,164,0.3);color:#5fcfff}
.ci2{background:rgba(0,156,143,0.3);color:#4dd9cf}
.ci3{background:rgba(193,87,0,0.25);color:#f7a96a}
.ci4{background:rgba(124,58,237,0.25);color:#c4a3f7}
.ci-label{font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:0.4rem}
.ci-val{font-size:0.88rem;color:#fff;line-height:1.55;font-weight:400}
.ci-val a{color:#5fcfff;text-decoration:none}
.ci-val a:hover{text-decoration:underline}

/* ─── GOOGLE FORM ─── */
.form-section{
  background:var(--bg2);padding:6rem;
  display:grid;grid-template-columns:1fr 1.4fr;gap:5rem;align-items:start;
}
.form-intro p{font-size:0.9rem;color:var(--muted);line-height:1.8;margin-bottom:1rem;font-weight:300}
.form-intro p:last-of-type{margin-bottom:2rem}
.socials-row{margin-top:2rem}
.socials-label{font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);margin-bottom:0.9rem}
.socials{display:flex;gap:0.75rem;flex-wrap:wrap}
.soc-btn{
  width:44px;height:44px;border-radius:50%;border:1px solid var(--border);
  cursor:pointer;transition:all 0.25s;
  display:flex;align-items:center;justify-content:center;
  background:var(--bg3);color:var(--slate);flex-shrink:0;
}
.soc-btn:hover{transform:translateY(-3px);box-shadow:0 4px 16px rgba(3,83,164,0.18);}
.soc-btn.x-btn:hover{border-color:#000;color:#000;box-shadow:0 4px 16px rgba(0,0,0,0.15);}
.soc-btn.ig-btn:hover{border-color:#d6249f;color:#d6249f;box-shadow:0 4px 16px rgba(214,36,159,0.2);}
.soc-btn.fb-btn:hover{border-color:#1877F2;color:#1877F2;box-shadow:0 4px 16px rgba(24,119,242,0.2);}
.soc-btn.yt-btn:hover{border-color:#FF0000;color:#FF0000;box-shadow:0 4px 16px rgba(255,0,0,0.18);}
.soc-btn.li-btn:hover{border-color:#0A66C2;color:#0A66C2;box-shadow:0 4px 16px rgba(10,102,194,0.2);}
.gform-wrap{
  background:var(--white);border:1px solid var(--border);
  border-radius:8px;overflow:hidden;
  box-shadow:0 4px 24px rgba(0,17,65,0.08);
}
.gform-header{
  background:var(--navy);padding:1.25rem 1.75rem;
  display:flex;align-items:center;gap:0.75rem;
}
.gform-header i{color:var(--sky);font-size:1.1rem}
.gform-header span{font-size:0.85rem;font-weight:600;color:#fff;letter-spacing:0.03em}
.gform-frame{
  width:100%;height:680px;border:none;display:block;
}

/* ─── FOOTER ─── */
footer{background:var(--navy);padding:5rem 6rem 2rem;color:rgba(255,255,255,0.7)}
.footer-top{
  display:grid;grid-template-columns:2fr 1fr 1.2fr 1fr;
  gap:3rem;padding-bottom:3.5rem;
  border-bottom:1px solid rgba(255,255,255,0.1);margin-bottom:2rem;
}
.footer-brand{
  font-family:'IBM Plex Serif',serif;font-size:1.2rem;font-weight:600;
  color:#fff;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;
}
.fh{
  font-size:0.62rem;letter-spacing:0.22em;text-transform:uppercase;
  color:rgba(255,255,255,0.45);margin-bottom:1rem;padding-bottom:0.6rem;
  border-bottom:1px solid rgba(255,255,255,0.1);font-weight:600;
}
.ft{font-size:0.8rem;color:rgba(255,255,255,0.55);line-height:1.8;margin-bottom:1rem;font-weight:300}
.fl{list-style:none}
.fl li{
  font-size:0.8rem;color:rgba(255,255,255,0.55);padding:0.28rem 0;
  cursor:default;transition:color 0.2s;display:flex;align-items:center;gap:0.4rem;
}
.fl li:hover{color:rgba(255,255,255,0.9)}
.fl li i{font-size:0.6rem;color:rgba(255,255,255,0.25)}
.map-img{border-radius:6px;border:1px solid rgba(255,255,255,0.12);display:block;margin-bottom:1rem}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
.footer-copy{font-size:0.72rem;color:rgba(255,255,255,0.4)}
.footer-socials{display:flex;gap:0.65rem}
.fsoc{
  width:38px;height:38px;border:1px solid rgba(255,255,255,0.15);border-radius:50%;
  cursor:pointer;transition:all 0.2s;
  display:flex;align-items:center;justify-content:center;
  color:rgba(255,255,255,0.55);background:transparent;flex-shrink:0;
}
.fsoc:hover{transform:scale(1.12);}
.fsoc.x-btn:hover{border-color:#fff;color:#fff;}
.fsoc.ig-btn:hover{border-color:#d6249f;color:#d6249f;}
.fsoc.fb-btn:hover{border-color:#1877F2;color:#1877F2;}
.fsoc.yt-btn:hover{border-color:#FF0000;color:#FF0000;}
.fsoc.li-btn:hover{border-color:#0A66C2;color:#0A66C2;}

/* ─── BTN VARIANTS ─── */
.btn-primary{
  padding:0.82rem 2.2rem;border-radius:4px;background:var(--blue-lt);
  color:#fff;border:2px solid var(--blue-lt);
  font-family:'IBM Plex Sans',sans-serif;font-size:0.82rem;
  font-weight:600;letter-spacing:0.05em;cursor:pointer;
  text-decoration:none;display:inline-flex;align-items:center;gap:0.5rem;
  transition:all 0.22s;
}
.btn-primary:hover{background:#0052a3;border-color:#0052a3;transform:translateY(-1px)}
.btn-outline{
  padding:0.82rem 2.2rem;border-radius:4px;background:transparent;
  border:2px solid var(--blue);color:var(--blue);
  font-family:'IBM Plex Sans',sans-serif;font-size:0.82rem;
  font-weight:600;letter-spacing:0.05em;cursor:pointer;
  text-decoration:none;display:inline-flex;align-items:center;gap:0.5rem;
  transition:all 0.22s;
}
.btn-outline:hover{background:rgba(3,83,164,0.07)}

/* ─── REVEAL ANIMATION ─── */
.reveal{opacity:0;transform:translateY(28px);transition:opacity 0.7s,transform 0.7s}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ─── RESPONSIVE ─── */
@media(max-width:900px){
  .nav-links,.nav-search-wrap{display:none}
  .about-grid,.trusted-grid,.form-section{grid-template-columns:1fr;gap:2.5rem}
  .trusted-img-wrap{order:0}
  .services-grid{grid-template-columns:1fr}
  .stats-band,.contact-cards{grid-template-columns:1fr 1fr}
  .footer-top{grid-template-columns:1fr 1fr}
  .section-wrap,.form-section,.contact-cards,.footer{padding-left:1.5rem;padding-right:1.5rem}
  .slide-content{padding:0 1.5rem}
  .hero-nav{left:1.5rem}
}
</style>
</head>
